# MicProbe Freemius checkout configuration
# Use sandbox while testing locally, production after live checkout is verified.
MICPROBE_FREEMIUS_MODE=sandbox

# Sandbox product configuration
MICPROBE_FREEMIUS_SANDBOX_PRODUCT_ID=
MICPROBE_FREEMIUS_SANDBOX_PLAN_ID=
MICPROBE_FREEMIUS_SANDBOX_CHECKOUT_URL=
MICPROBE_FREEMIUS_SANDBOX_SUCCESS_URL=http://localhost:8080/app
MICPROBE_FREEMIUS_SANDBOX_BILLING_CYCLE=lifetime
MICPROBE_FREEMIUS_SANDBOX_CHECKOUT_TITLE=MicProbe Premium

# Production product configuration
MICPROBE_FREEMIUS_PRODUCTION_PRODUCT_ID=
MICPROBE_FREEMIUS_PRODUCTION_PLAN_ID=
MICPROBE_FREEMIUS_PRODUCTION_CHECKOUT_URL=
MICPROBE_FREEMIUS_PRODUCTION_SUCCESS_URL=
MICPROBE_FREEMIUS_PRODUCTION_BILLING_CYCLE=lifetime
MICPROBE_FREEMIUS_PRODUCTION_CHECKOUT_TITLE=MicProbe Premium

# Keep secrets outside client-side code. They are used only by server.js.
MICPROBE_FREEMIUS_SANDBOX_PRODUCT_SECRET=
MICPROBE_FREEMIUS_PRODUCTION_PRODUCT_SECRET=

# Backward-compatible fallback names. Prefer the sandbox/production names above.
MICPROBE_FREEMIUS_PRODUCT_ID=
MICPROBE_FREEMIUS_PLAN_ID=
MICPROBE_FREEMIUS_CHECKOUT_URL=
MICPROBE_FREEMIUS_SUCCESS_URL=
MICPROBE_FREEMIUS_BILLING_CYCLE=
MICPROBE_FREEMIUS_CHECKOUT_TITLE=
MICPROBE_FREEMIUS_PRODUCT_SECRET=
